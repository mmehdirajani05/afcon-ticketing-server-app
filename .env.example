APP_NAME="AFCON 2027 Ticketing"

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_APP_NAME="AFCON Admin"
ADMIN_APP_SUBTITLE="Africa Cup of Nations 2027"
ADMIN_PRIMARY_COLOR="#008EC0"
ADMIN_PRIMARY_COLOR_DARK="#006B91"
ADMIN_PRIMARY_COLOR_LIGHT="#40BADF"
ADMIN_PER_PAGE=20
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=afcon_ticketing
DB_USERNAME=root
DB_PASSWORD=

# ── Session / Cache ───────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@afcon2027.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ── Social Auth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_KEY_FILE=storage/apple/AuthKey.p8

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS=storage/firebase/service-account.json
FIREBASE_PROJECT_ID=
FIREBASE_SERVER_KEY=

# ── Immigration API ───────────────────────────────────────────────────────────
# IMMIGRATION_SKIP=true → bypass immigration entirely, Fan ID issued instantly (dev only)
IMMIGRATION_SKIP=false
# Mode: realtime = instant API call | delayed = manual/admin review (up to 24h)
IMMIGRATION_MODE=delayed
IMMIGRATION_API_URL=
IMMIGRATION_API_KEY=

# ── CAF Ticketing API ─────────────────────────────────────────────────────────
CAF_API_URL=
CAF_API_KEY=
CAF_API_TIMEOUT=15

# ── NMB Payment Gateway ───────────────────────────────────────────────────────
NMB_API_URL=
NMB_MERCHANT_ID=
NMB_SECRET_KEY=
NMB_REDIRECT_URL="${APP_URL}/payment/complete"
NMB_API_TIMEOUT=15

# ── Redis (optional — only if needed for rate limiting) ───────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── AWS (optional) ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
